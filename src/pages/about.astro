---
import Layout from '~/layouts/Layout.astro'
import CertPreview from '~/components/CertPreview.astro'
import SkillsSection from '~/components/SkillsSection.astro'
import SkillsCategorySection from '~/components/SkillsCategorySection.astro'
import { getSortedCerts, getSortedSkills } from '~/utils'
import { Icon } from 'astro-icon/components'

const sortedCerts = await getSortedCerts()
const sortedSkills = await getSortedSkills()
---

<Layout title="Certifications & Skills" description="My professional certifications and skills">
  <div class="max-w-full py-7.5">

    <!-- About Section -->
    <section class="mb-12">
      <h1 class="md:mx-2 mb-3 text-[1.75rem] text-heading1 font-semibold flex items-center justify-between">
        <span># About</span>
        <Icon name="ph:user" class="size-7" />
      </h1>

      <hr class="border-accent/10 border-2 rounded-xl my-6" />

      <div class="prose">
        <p>My name is Simeon Nedkov, systems administrator with a passion for deploying and maintaining server 
           and network infrastructure. I recently discovered that the cyber security field is a lot of fun too (as long as you 
           are not on the receiving end). This blog aims to develop and extend my skills in infrastructure and security, and yours hopefully.
        </p>

        <p>When I am not doing IT stuff, I like to do architectural visualiazition. Check out my <a href="https://www.behance.net/aliwalil" target="_blank" rel="noopener noreferrer" class="text-accent">gallery.</a>
        </p>
      </div>
    </section>
    
    <!-- Skills Section -->
    <section class="mb-12">
      <h1 class="md:mx-2 mb-3 text-[1.75rem] text-heading1 font-semibold flex items-center justify-between">
        <span># Tech Stack</span>
        <Icon name="ph:wrench" class="size-7" />
      </h1>

      <!-- Divider -->
      <hr class="border-accent/10 border-2 rounded-xl my-6" />

      <div class="mb-5 prose">
        <p>My technical skills and areas of expertise.</p>
      </div>
      
      <!-- Skills by Category -->
      <SkillsCategorySection category="Infrastructure" skills={sortedSkills} />
      <SkillsCategorySection category="Networking & Security" skills={sortedSkills} />
      <SkillsCategorySection category="Observability & Asset Management" skills={sortedSkills} />
      
      <!-- All skills tags -->
      {
        sortedSkills.length > 0 ? (
          <SkillsSection skills={sortedSkills} />
        ) : (
          <p class="text-foreground/70">No skills listed yet.</p>
        )
      }
    </section>

    <!-- Certifications Section -->
    <section>
      <h1 class="md:mx-2 mb-3 text-[1.75rem] text-heading1 font-semibold flex items-center justify-between">
        <span># Certifications</span>
        <Icon name="ph:certificate" class="size-7" />
      </h1>

      <!-- Divider -->
      <hr class="border-accent/10 border-2 rounded-xl my-6" />


      <div class="mb-5 prose">
        <p>A collection of my professional certifications and achievements.</p>
      </div>
      {
        sortedCerts.length > 0 ? (
          <div class="space-y-4">
            {sortedCerts.map((cert) => (
              <CertPreview cert={cert} />
            ))}
          </div>
        ) : (
          <p class="text-foreground/70">No certifications yet.</p>
        )
      }
    </section>

  </div>
</Layout>
