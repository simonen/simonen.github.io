---
import Layout from '~/layouts/Layout.astro'
import SkillPreview from '~/components/SkillPreview.astro'
import { getSortedSkills } from '~/utils'

const sortedSkills = await getSortedSkills()
---

<Layout title="Skills" description="My technical skills and expertise">
  <div class="max-w-full py-7.5">
    <h1 class="md:mx-2 mb-3 text-[1.75rem] text-heading1 font-semibold">
      # Skills
    </h1>
    
    <div class="mb-5 prose">
      <p>My technical skills and areas of expertise.</p>
    </div>

    {
      sortedSkills.length > 0 ? (
        <div class="space-y-4">
          {sortedSkills.map((skill) => (
            <SkillPreview skill={skill} />
          ))}
        </div>
      ) : (
        <p class="text-foreground/70">No skills listed yet.</p>
      )
    }
  </div>
</Layout>
