---
import type { CollectionEntry } from 'astro:content'
import { getSortedSkills } from '~/utils'

interface Props {
  category: string
  skills?: CollectionEntry<'skills'>[]
}

const { category, skills } = Astro.props
const allSkills = skills || await getSortedSkills()
const categorySkills = allSkills.filter(skill => skill.data.category === category)
---

{
  categorySkills.length > 0 && (
    <div class="mb-8">
      <h3 class="text-xl font-semibold text-heading1 mb-3">{category}</h3>
      <div class="grid gap-3">
        {categorySkills.map((skill) => (
          <div class="flex items-start gap-3 p-3 bg-accent/5 rounded-lg border border-accent/10">
            {
              skill.data.icon && (
                <span class="text-2xl">{skill.data.icon}</span>
              )
            }
            <div>
              <h4 class="font-medium text-foreground">{skill.data.title}</h4>
              {skill.data.description && (
                <p class="text-sm text-foreground/70">{skill.data.description}</p>
              )}
              {skill.data.subcategory && (
                <span class="text-xs bg-accent/10 text-accent px-2 py-0.5 rounded-full mt-1 inline-block">
                  {skill.data.subcategory}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
